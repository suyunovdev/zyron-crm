# === Zyron Academy — muhit o'zgaruvchilari namunasi ===
# Bu faylni `.env` ga nusxalab, qiymatlarni to'ldiring.
# .env hech qachon git'ga qo'shilmaydi (maxfiy).

# --- Ma'lumotlar bazasi ---
# Lokal (dev): SQLite
DATABASE_URL="file:./dev.db"
# Production (tavsiya): PostgreSQL / Neon
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- Autentifikatsiya ---
# JWT imzolash kaliti. Kuchli, tasodifiy 32+ belgi bo'lsin.
# Yaratish: openssl rand -base64 32
JWT_SECRET="bu-yerga-kuchli-tasodifiy-kalit"

# --- Cron ---
# auto-absent endpoint uchun maxfiy header qiymati.
# Yaratish: openssl rand -hex 24
CRON_SECRET="bu-yerga-kuchli-tasodifiy-sekret"

# --- Webhook ---
# Saytdan lid qabul qilish endpoint'i uchun maxfiy header.
WEBHOOK_SECRET="bu-yerga-kuchli-tasodifiy-sekret"
