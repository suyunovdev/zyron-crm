generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  login     String   @unique
  password  String
  rawPass   String?
  name      String
  phone     String?
  role      String   @default("student") // superadmin, admin, teacher, student, parent
  subject   String?  // faqat teacher uchun (fan nomi)
  status    String   @default("active") // active, frozen, archived
  level     String?  // teacher: senior, middle, junior
  avatar    String?  // rasm URL
  parentId  String?  // parent user ID — farzandni bog'lash uchun
  parent    User?    @relation("ParentChild", fields: [parentId], references: [id])
  children  User[]   @relation("ParentChild")
  branchId  String?  // filial (multi-branch)
  branch    Branch?  @relation(fields: [branchId], references: [id])
  salaryShare  Int?     // ustoz uchun: yig'ilgan to'lovdan ulush (%)
  tokenVersion Int   @default(0) // majburiy logout uchun — bumping barcha eski tokenlarni bekor qiladi
  createdAt DateTime @default(now())

  teacherGroups Group[]
  groupStudents GroupStudent[]
  attendances   Attendance[]
  payments      Payment[]
  notes         Note[]

  @@index([role, status])
  @@index([parentId])
  @@index([branchId])
}

model Group {
  id          String   @id @default(cuid())
  name        String
  subject     String
  teacherId   String
  teacher     User     @relation(fields: [teacherId], references: [id])
  schedule    String
  meetLink    String
  mode        String   @default("offline") // offline, online
  status      String   @default("active") // active, archived
  maxStudents Int      @default(15)
  startDate   String?  // guruh boshlanish sanasi
  room        String?  // xona raqami (Room 7, Room 8...)
  dayType     String   @default("toq") // toq, juft, boshqa
  time        String?  // dars vaqti (14:00, 18:40...)
  language    String   @default("uz") // uz, ru, en
  price       Int      @default(0)   // oylik kurs narxi (so'mda)
  lessonsPerMonth Int  @default(12)  // oyiga nechta dars
  branchId    String?  // filial (multi-branch)
  branch      Branch?  @relation(fields: [branchId], references: [id])
  createdAt   DateTime @default(now())

  students GroupStudent[]
  lessons  Lesson[]

  @@index([teacherId])
  @@index([status])
  @@index([branchId])
}

model GroupStudent {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id])
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  joinedAt  DateTime @default(now())

  @@unique([groupId, studentId])
  @@index([studentId])
}

model Lesson {
  id            String   @id @default(cuid())
  groupId       String
  group         Group    @relation(fields: [groupId], references: [id])
  topic         String?
  scheduledDate String
  scheduledTime String
  duration      String   @default("1.5 soat")
  order         Int
  createdAt     DateTime @default(now())

  attendances Attendance[]

  @@index([groupId])
  @@index([scheduledDate])
}

model Attendance {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  present   Boolean
  scoreAttend   Int  @default(0) // 0-5 qatnashish balli
  scoreHomework Int  @default(0) // 0-5 uyga vazifa balli
  scoreActivity Int  @default(0) // 0-5 faollik balli
  markedAt  DateTime @default(now())

  @@unique([lessonId, studentId])
  @@index([studentId, present])
}

model Payment {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  amount    Int      // so'mda (refund uchun manfiy bo'lishi mumkin)
  month     String   // "2026-07" formatda
  method    String   @default("cash") // cash, card, transfer
  type      String   @default("payment") // payment, refund, discount
  note      String?
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([month])
}

model Note {
  id        String   @id @default(cuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id])
  type      String   @default("comment") // comment, frozen, archived, status
  text      String
  createdAt DateTime @default(now())

  @@index([studentId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // lead, payment, enrollment, attendance, system
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?  // sahifaga yo'naltirish
  branchId  String?  // filial (multi-branch) — null = global (barcha adminlarga)
  createdAt DateTime @default(now())

  @@index([read, createdAt])
  @@index([branchId])
}

model Lead {
  id          String   @id @default(cuid())
  leadId      String   @unique @default(cuid()) // auto-generated LeadID
  name        String
  surname     String?
  phone       String
  gender      String?  // male, female
  birthDate   String?
  guardianPhone String?
  guardianName  String?
  guardianType  String?  // ota, ona, aka, opa, boshqa
  preferredLang String?  // uz, ru, en
  source      String?  // telegram, instagram, do'stlar, boshqa
  status      String   @default("new") // new, contacted, trial, enrolled, rejected
  note        String?
  prepayment  Int?     // oldindan to'lov summasi
  branchId    String?  // filial (multi-branch)
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
  @@index([branchId])
}

// Audit jurnali — kim nima o'zgartirgani (javobgarlik/nazorat)
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actorName String
  actorRole String
  action    String   // create, update, delete, reset-password, login-as, force-logout, ...
  entity    String   // user, admin, payment, group, setting, branch, system
  entityId  String?
  summary   String   // o'qiladigan tavsif
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
  @@index([actorId])
}

// Tizim sozlamalari (key-value)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Filial (multi-branch)
model Branch {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  createdAt DateTime @default(now())

  users  User[]
  groups Group[]
}

// SMS/Telegram tarqatma jurnali
model SmsCampaign {
  id             String   @id @default(cuid())
  message        String
  audience       String   // leads, students, debtors, all
  channel        String   @default("sms") // sms, telegram
  recipientCount Int      @default(0)
  status         String   @default("queued") // queued, sent, failed
  createdAt      DateTime @default(now())
}

// Ticket — ustoz admin yoki ota-onaga so'rov/muammo yozadi (thread)
// AuditLog kabi: User'ga relation yo'q, sof id maydonlar.
model Ticket {
  id               String   @id @default(cuid())
  authorId         String   // ustoz (muallif)
  authorName       String
  recipientType    String   // admin | parent
  recipientId      String?  // ota-ona user id (recipientType=parent bo'lsa)
  relatedStudentId String?  // qaysi o'quvchi haqida (ixtiyoriy/kontekst)
  relatedStudentName String?
  category         String   // attendance, schedule, salary, student, technical, leave, other
  subject          String
  priority         String   @default("normal") // low, normal, high
  status           String   @default("open")   // open, in_progress, resolved, closed
  teacherUnread    Boolean  @default(false)     // ustoz uchun o'qilmagan javob bormi
  recipientUnread  Boolean  @default(true)      // qabul qiluvchi uchun o'qilmagan bormi
  branchId         String?  // filial (multi-branch) — muallif ustozning filiali
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  messages TicketMessage[]

  @@index([authorId])
  @@index([recipientType, status])
  @@index([recipientId])
  @@index([branchId])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String
  senderName String
  senderRole String
  body       String
  createdAt  DateTime @default(now())

  @@index([ticketId])
}
